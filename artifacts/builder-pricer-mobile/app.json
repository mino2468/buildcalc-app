{
  "expo": {
    "name": "BuildCalc – Wycena Robót",
    "slug": "builder-pricer-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "builder-pricer-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EA580C"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.mino13579.buildcalc"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "893f8552-552d-441f-9098-dd5330bd4603"
      }
    },
    "owner": "mino13579-2"
  }
}
